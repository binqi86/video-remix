{
  "name": "video-remix",
  "productName": "Video Remix",
  "version": "1.0.0",
  "description": "AI视频二创工具 - 基于参考视频自动分段、角色替换、生成拼接",
  "main": "build/main.js",
  "scripts": {
    "dev": "tsx src/app.ts",
    "dev:gui": "node node_modules/electron/cli.js scripts/electron-entry.js",
    "dev:all": "cd infinite-canvas/web && bun run dev & npm run dev",
    "build": "tsc",
    "start": "NODE_PATH=$(pwd)/node_modules electron .",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "setup": "npm install && cd infinite-canvas/web && bun install",
    "rebuild:node": "npm rebuild better-sqlite3 sharp",
    "rebuild:electron": "electron-rebuild"
  },
  "dependencies": {
    "@tensorflow/tfjs-node": "^4.20.0",
    "@vladmandic/face-api": "^1.7.15",
    "axios": "^1.6.5",
    "canvas": "^3.2.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-ws": "^5.0.2",
    "js-md5": "^0.8.3",
    "lodash": "^4.17.21",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.4",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/lodash": "^4.17.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electronmon": "^2.0.4",
    "nodemon": "^3.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
